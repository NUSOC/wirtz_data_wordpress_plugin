<div class="wrap">
    <h1>Wirtz Data Settings</h1>
    
    {% if messages %}
        {% for message in messages %}
            <div class="notice notice-{{ message.type }} is-dismissible">
                <p>{{ message.text }}</p>
            </div>
        {% endfor %}
    {% endif %}
    
    <form method="post" action="options.php">
        {{ settings_fields|raw }}
        {{ do_settings_sections|raw }}
        {{ submit_button|raw }}
    </form>
</div>

{% if csv_files_data.files %}
<div class="wrap" style="margin-top: 20px;">
    <h2>CSV Files</h2>
    <table class="widefat">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Size</th>
                <th>Modified</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for file in csv_files_data.files %}
            <tr>
                <td>{{ file.filename }}</td>
                <td>{{ file.size }}</td>
                <td>{{ file.modified }}</td>
                <td>
                    <form method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete {{ file.filename }}?');">
                        <input type="hidden" name="delete_csv_file" value="{{ file.filename }}">
                        <input type="hidden" name="_wpnonce" value="{{ file.nonce }}">
                        <input type="submit" value="Delete" class="button button-secondary button-small">
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% elseif csv_files_data.error %}
<div class="wrap" style="margin-top: 20px;">
    <h2>CSV Files</h2>
    <p><em>{{ csv_files_data.error }}</em></p>
</div>
{% endif %}

{% if logs %}
<div class="wrap" style="margin-top: 20px;">
    <table class="widefat fixed striped">
        <thead>
            <tr>
                {% for header in log_headers %}
                <th>{{ header }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for log in logs %}
            <tr>
                {% for value in log %}
                <td>{{ value }}</td>
                {% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}